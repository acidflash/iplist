# Port the app is served on (host port)
PORT=8080

# Secret key used to sign JWT tokens — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Path to the SQLite database inside the container (matches the Docker volume)
DB_PATH=/data/iplist.db

# Initial admin password, set only on first start when the database is empty.
# If unset, a default 'admin'/'admin' user is created (and a warning is logged).
ADMIN_PASSWORD=

# Optional: password for a read-only 'reader' user, created on first start.
# If unset, no reader account is created.
READER_PASSWORD=
